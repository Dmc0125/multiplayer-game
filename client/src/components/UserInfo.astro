---
type Props = {
    name: string
    wins: number
    losses: number
    spWins: number
    spLosses: number
}
const { name, wins, losses, spWins, spLosses } = Astro.props
const avatarUrl = `https://api.dicebear.com/10.x/thumbs/svg?seed=${name}`
---

<div class="mt-10 flex flex-col">
    <div class="mt-10 flex items-center justify-center gap-4">
        <img class="w-6 h-6 rounded-full" src={avatarUrl} alt="avatar" />
        <h2 class="text-light-2">{name}</h2>
    </div>

    <div class="mt-5 grid grid-cols-[auto_auto] gap-x-4 gap-y-2">
        <p class="text-light-2 text-sm">Wins</p>
        <p class="text-light-2 text-sm">{wins}</p>

        <p class="text-light-2 text-sm">Losses</p>
        <p class="text-light-2 text-sm">{losses}</p>

        <p class="text-light-2 text-sm">Singleplayer wins</p>
        <p class="text-light-2 text-sm">{spWins}</p>

        <p class="text-light-2 text-sm">Singleplayer losses</p>
        <p class="text-light-2 text-sm">{spLosses}</p>
    </div>
</div>

---
import Layout from "../Layout.astro"
import Game from "../components/Game.astro"
---

<Layout>
    <div class="pt-[10%] px-5 sm:px-0 flex flex-col items-center justify-center">
        <h1 class="text-dark text-xl sm:text-4xl font-bold">Multiplayer</h1>
        <Game />
    </div>
</Layout>

<script>
    const canvas = document.getElementById("canvas") as HTMLCanvasElement
    const ctx = canvas.getContext("2d")!

    function resizeCanvas() {
        ctx.setTransform(1, 0, 0, 1, 0, 0)

        const r = canvas.getBoundingClientRect()
        canvas.width = r.width
        canvas.height = r.height

        const scaleX = canvas.width / 800
        const scaleY = canvas.height / 400
        ctx.scale(scaleX, scaleY)
    }

    window.addEventListener("DOMContentLoaded", resizeCanvas)
    window.addEventListener("resize", resizeCanvas)

    const gameWidth = 800
    const gameHeight = 400

    let connId: number | null = null

    // ws

    const MESSAGE_TYPE_CONN_ID = 0
    const MESSAGE_TYPE_GAME_START = 1
    const MESSAGE_TYPE_GAME_RESTART = 2
    const MESSAGE_TYPE_GAME_END = 3
    const MESSAGE_TYPE_GAME_STATE = 4
    const MESSAGE_TYPE_KEY = 5
    const MESSAGE_TYPE_LEAVE = 6

    const keyCodeMap: Record<string, number> = {
        ArrowUp: 0,
        ArrowDown: 1,
    }

    const messageGameEnd = document.getElementById("message-game-end") as HTMLDivElement
    const btnPlayAgain = document.getElementById("btn-play-again") as HTMLButtonElement

    window.addEventListener("DOMContentLoaded", () => {
        const ws = new WebSocket("ws://localhost:8080/ws")
        ws.binaryType = "arraybuffer"

        function encodeKeyMsg(keyCode: number, down: boolean): Uint8Array<ArrayBuffer> {
            const data = new Uint8Array(3)
            const view = new DataView(data.buffer)
            view.setUint8(0, MESSAGE_TYPE_KEY)
            view.setUint8(1, keyCode)
            view.setUint8(2, down ? 1 : 0)
            return data
        }

        window.addEventListener("keydown", (event) => {
            if (ws.readyState === ws.OPEN) {
                if (event.key === "r" && !messageGameEnd.classList.contains("hidden")) {
                    ws.send(new Uint8Array([MESSAGE_TYPE_GAME_RESTART]))
                    messageGameEnd.classList.add("hidden")
                    return
                }

                const keyCode = keyCodeMap[event.key]
                if (keyCode !== undefined) {
                    ws.send(encodeKeyMsg(keyCode, true))
                }
            }
        })

        window.addEventListener("keyup", (event) => {
            if (ws.readyState === ws.OPEN) {
                const keyCode = keyCodeMap[event.key]
                if (keyCode !== undefined) {
                    ws.send(encodeKeyMsg(keyCode, false))
                }
            }
        })

        btnPlayAgain.addEventListener("click", () => {
            ws.send(new Uint8Array([MESSAGE_TYPE_GAME_RESTART]))
            messageGameEnd.classList.add("hidden")

            const waitingMessageElement = document.getElementById("msg-waiting")!
            waitingMessageElement.classList.remove("hidden")
        })

        ws.onmessage = function (event) {
            const data = event.data
            if (!(data instanceof ArrayBuffer)) {
                return
            }

            const view = new DataView(data)
            const messageType = view.getUint8(0)

            switch (messageType) {
                case MESSAGE_TYPE_CONN_ID: {
                    const connectingMessageElement = document.getElementById("msg-connecting")!
                    connectingMessageElement.classList.add("hidden")

                    connId = view.getUint32(1, true)

                    const startMessageData = new Uint8Array(2)
                    startMessageData[0] = MESSAGE_TYPE_GAME_START
                    startMessageData[1] = 1
                    ws.send(startMessageData)

                    const waitingMessageElement = document.getElementById("msg-waiting")!
                    waitingMessageElement.classList.remove("hidden")

                    break
                }
                case MESSAGE_TYPE_GAME_START:
                    const waitingMessageElement = document.getElementById("msg-waiting")!
                    waitingMessageElement.classList.add("hidden")
                case MESSAGE_TYPE_GAME_STATE: {
                    ctx.clearRect(0, 0, gameWidth, gameHeight)

                    let offset = 1

                    function decodef32(): number {
                        const f = view.getFloat32(offset, true)
                        offset += 4
                        return f
                    }

                    // paddles

                    for (let i = 0; i < 2; i++) {
                        const c = view.getUint32(offset, true)
                        offset += 4

                        const paddleX = decodef32()
                        const paddleY = decodef32()
                        const paddleWidth = decodef32()
                        const paddleHeight = decodef32()

                        ctx.fillStyle = "#dd6e42"
                        if (c === connId) {
                            ctx.fillStyle = "#eaeaea"
                        }

                        const y = gameHeight - paddleY - paddleHeight
                        ctx.beginPath()
                        ctx.roundRect(paddleX, y, paddleWidth, paddleHeight, 10)
                        ctx.fill()
                    }

                    // ball

                    const ballX = decodef32()
                    const ballY = decodef32()
                    const ballRadius = decodef32()

                    ctx.fillStyle = "#e8dab2"
                    ctx.beginPath()
                    const y = gameHeight - ballY
                    ctx.arc(ballX, y, ballRadius, 0, 2 * Math.PI)
                    ctx.fill()

                    break
                }
                case MESSAGE_TYPE_GAME_END: {
                    const player1Score = document.getElementById("player1-score") as HTMLSpanElement
                    const player2Score = document.getElementById("player2-score") as HTMLSpanElement

                    const winner = view.getUint8(1)
                    let playerNumber: number

                    if (winner === 0) {
                        player1Score.textContent = String(parseInt(player1Score.textContent) + 1)
                        playerNumber = 1
                    } else if (winner === 1) {
                        player2Score.textContent = String(parseInt(player2Score.textContent) + 1)
                        playerNumber = 2
                    } else {
                        throw new Error("Invalid winner")
                    }

                    messageGameEnd.classList.remove("hidden")

                    const playerNumberElement = messageGameEnd.querySelector(
                        "#player-number",
                    ) as HTMLSpanElement
                    playerNumberElement.textContent = String(playerNumber)

                    break
                }
                case MESSAGE_TYPE_LEAVE: {
                    const waitingMessageElement = document.getElementById("msg-waiting")!
                    waitingMessageElement.classList.remove("hidden")

                    messageGameEnd.classList.add("hidden")
                    break
                }
            }
        }
    })
</script>
